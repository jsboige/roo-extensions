debug_payload_dump.json
debug_trace.txt
test-output.txt
test-result.txt
test-debug-*.log
test-debug-*.cjs
test-debug-*.html

# Coverage reports
coverage/
*.lcov
lcov-report/

# Win-CLI local config, logs, and temp files (machine-specific)
mcps/external/win-cli/server/config.json
mcps/external/win-cli/server/*.txt
mcps/external/win-cli/server/.claude/
mcps/external/win-cli/server/test-*.js
mcps/external/win-cli/server/node_modules/

# Claude Code Provider Switcher - Real API keys (NEVER commit these!)
.claude/configs/provider.*.json
!.claude/configs/provider.*.template.json

# Claude Code settings backups
.claude/settings.json.backup-*

# Claude Code local settings (machine-specific overrides, never commit)
.claude/settings.local.json

# Claude Code local inter-agent communication (machine-specific)
.claude/local/

# Claude Code MCP configuration (machine-specific paths)
.mcp.json

.claude/config.json

# Claude Code worktrees (machine-specific, created by Claude Code Desktop)
.claude/worktrees/

# Claude Code temporary working directories
tmpclaude-*/

# Claude Code local overrides (machine-specific, never commit)
CLAUDE.local.md
*.local.md
scripts/setup/.env
.claude/scheduler/

# Roo modes (deployed to global settings, not project)
.roomodes

# Auto-import settings (contains API keys)
roo-config/roo-settings-import.json
roo-config/roo-settings-import.json.*
exports/
.roo/schedules.json

# Session artifacts (reports, audits created during agent sessions - never commit to root)
# These match ONLY at repo root (leading slash). Use archive/ or docs/ for permanent storage.
/*-REPORT.md
/*-report.md
/report-*.md
/audit-*.md
/TEST-*.md

# RooSync config collection temp dirs
.temp/config-collect-*/

# Runtime lock files and socket files at root
/*.json.lock
/*.lock

# Backup dirs created by agent sessions
/backup-*/
/cleanup-backups/

# sk-agent config with hardcoded API keys (CRITICAL - never commit)
mcps/internal/servers/sk-agent/sk_agent_config.json

# Test and debug output directories
/outputs/
/test-outputs/

# IMPORTANT: Scripts MUST write debug output to outputs/debug/, NOT the root directory
# The .gitignore is NOT a cleanup tool - fix the scripts to clean up after themselves

# Transient agent reports (meta-analysis, patrol) — share via dashboards/issues instead
docs/harness/meta-analysis-report-*.md

# Archives directory (historical git is sufficient, no need for _archives/)
_archives/
