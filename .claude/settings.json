{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000"
  },
  "permissions": {
    "allow": [
      "Bash(powershell -ExecutionPolicy Bypass -File:*)",
      "Bash(powershell:*)",
      "Bash(claude:*)",
      "Bash(code:*)",
      "Bash(Select-String \"claude\")",
      "Bash(Test-Path:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(test:*)",
      "Bash(cat:*)",
      "Bash(node:*)",
      "Bash(git submodule:*)",
      "Bash(git push:*)",
      "Bash(npm run build:*)",
      "Bash(npm --version)",
      "Bash(timeout 5 node:*)",
      "Bash(timeout:*)",
      "mcp__roo-state-manager__roosync_read_inbox",
      "mcp__roo-state-manager__roosync_get_message",
      "Bash(gh issue comment:*)",
      "mcp__roo-state-manager__roosync_mark_message_read",
      "mcp__roo-state-manager__roosync_send_message",
      "Skill(sync-tour)",
      "Skill(sync-tour:*)",
      "Bash(git pull:*)",
      "mcp__roo-state-manager__roosync_get_machine_inventory",
      "mcp__roo-state-manager__roosync_collect_config",
      "Bash(npx vitest:*)",
      "Edit:.claude/local/*",
      "Write:.claude/local/*"
    ],
    "mode": "auto-approve"
  },
  "outputStyle": "default"
}
